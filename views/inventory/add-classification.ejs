<div class="add-class-container">
  <h1><%= title %></h1>
  
  <% if (typeof messages !== 'undefined' && messages.error) { %>
    <div class="error-message"><%= messages.error %></div>
  <% } %>
  
  <% if (typeof errors !== 'undefined' && errors && errors.length > 0) { %>
    <ul class="error-list">
      <% errors.forEach(error => { %> 
        <li><%= error.msg %></li> 
      <% }) %>
    </ul>
  <% } %>

  <form action="/inv/add-classification" method="post">
    <label for="classification_name">Classification Name:</label>
    <span>(No spaces or special characters allowed)</span>
    <input 
      type="text" 
      name="classification_name" 
      id="classification_name" 
      required 
      pattern="^[a-zA-Z0-9]+$"
      value="<%= classification_name %>"
    />
    <button type="submit">Add Classification</button>
  </form>
</div>