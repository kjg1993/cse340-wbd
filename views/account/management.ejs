<h2>Account Management</h2>
<%- messages() %>

<h3>Welcome, <%= accountData.account_firstname %> <%= accountData.account_lastname %></h3>

<p>You are logged in.</p>

<p><a href="/account/edit/<%= accountData.account_id %>">Edit Account Information</a></p>

<% if (accountData.account_type === 'Admin' || accountData.account_type === 'Employee') { %>
    <h3>Inventory Management</h3>
    <p><a href="/inv/">Manage Inventory</a></p>
<% } %>