<h2>Account Management</h2>
<%- messages() %>

<h3>Welcome, <%= locals.accountData.account_firstname %> <%= locals.accountData.account_lastname %></h3>

<p>You are logged in.</p>

<div class="account-actions">
    <h3>Account Settings</h3>
    <p>
        <a href="/account/update/<%= locals.accountData.account_id %>" title="Click to update account information">
            Update Account Information
        </a>
    </p>
</div>

<% if (locals.accountData.account_type === 'Admin' || locals.accountData.account_type === 'Employee') { %>
    <div class="admin-actions">
        <h3>Inventory Management</h3>
        <p>
            <a href="/inv/" title="Manage vehicle inventory">Manage Inventory</a>
        </p>
    </div>
<% } %>